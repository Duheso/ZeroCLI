{
  "$schema": "vscode://schemas/color-theme",
  "name": "Zero CLI Terminal Black",
  "type": "dark",
  "colors": {
    "editor.background": "#0a0a0f",
    "editor.foreground": "#e8e8f5",
    "editorCursor.foreground": "#22d3ee",
    "editorLineNumber.foreground": "#3d3d5c",
    "editorLineNumber.activeForeground": "#7878a0",
    "editor.selectionBackground": "#1a1a2e",
    "editor.inactiveSelectionBackground": "#141420",
    "editor.wordHighlightBackground": "#1a1a2e44",
    "editor.wordHighlightStrongBackground": "#24245066",
    "editorIndentGuide.background1": "#141420",
    "editorIndentGuide.activeBackground1": "#2a2a50",
    "editorBracketMatch.background": "#25255066",
    "editorBracketMatch.border": "#22d3ee",
    "terminal.background": "#0a0a0f",
    "terminal.foreground": "#e8e8f5",
    "terminalCursor.background": "#22d3ee",
    "terminalCursor.foreground": "#22d3ee",
    "terminal.ansiBlack": "#0a0a0f",
    "terminal.ansiRed": "#f87171",
    "terminal.ansiGreen": "#4ade80",
    "terminal.ansiYellow": "#fbbf24",
    "terminal.ansiBlue": "#60a5fa",
    "terminal.ansiMagenta": "#a78bfa",
    "terminal.ansiCyan": "#22d3ee",
    "terminal.ansiWhite": "#e8e8f5",
    "terminal.ansiBrightBlack": "#4a4a6a",
    "terminal.ansiBrightRed": "#fca5a5",
    "terminal.ansiBrightGreen": "#86efac",
    "terminal.ansiBrightYellow": "#fcd34d",
    "terminal.ansiBrightBlue": "#93c5fd",
    "terminal.ansiBrightMagenta": "#c4b5fd",
    "terminal.ansiBrightCyan": "#67e8f9",
    "terminal.ansiBrightWhite": "#f5f5ff",
    "statusBar.background": "#0f0f18",
    "statusBar.foreground": "#e8e8f5",
    "activityBar.background": "#0d0d14",
    "activityBar.foreground": "#e8e8f5",
    "sideBar.background": "#0b0b12",
    "sideBar.foreground": "#b0b0cc",
    "titleBar.activeBackground": "#0b0b12",
    "titleBar.activeForeground": "#e8e8f5"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#5a5a7a", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#a78bfa" }
    },
    {
      "scope": ["string", "constant.other.symbol"],
      "settings": { "foreground": "#4ade80" }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#fbbf24" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#60a5fa" }
    },
    {
      "scope": ["variable", "entity.name.variable"],
      "settings": { "foreground": "#e8e8f5" }
    },
    {
      "scope": ["entity.name.type", "support.type", "entity.name.class"],
      "settings": { "foreground": "#22d3ee" }
    }
  ]
}
